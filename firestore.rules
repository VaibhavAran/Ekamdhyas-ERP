
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Admins
    match /admins/{document=**} {
      allow read, write: if signedIn();
    }

    // Faculty / Teachers
    match /faculty/{document=**} {
      allow read, write: if signedIn();
    }

    // Students
    // Includes face registration metadata fields:
    // face_registered, face_registration_status, face_image_count,
    // face_folder_path, face_last_updated
    match /students/{document=**} {
      allow read, write: if signedIn();
    }

    // Departments
    match /departments/{document=**} {
      allow read, write: if signedIn();
    }

    // Classes
    match /classes/{document=**} {
      allow read, write: if signedIn();
    }

    // Batches
    match /batches/{document=**} {
      allow read, write: if signedIn();
    }

    // Subjects
    match /subjects/{document=**} {
      allow read, write: if signedIn();
    }

    // Timetable
    match /timetable/{document=**} {
      allow read, write: if signedIn();
    }

    // Attendance
    match /attendance/{document=**} {
      allow read, write: if signedIn();
    }

    // Attendance Sessions
    match /attendance_sessions/{document=**} {
      allow read, write: if signedIn();
    }

    // Attendance Images
    match /attendance_images/{document=**} {
      allow read, write: if signedIn();
    }

    /* ==========================
       SUBSTITUTE REQUESTS
       Teacher absent requests
    ========================== */
    match /substitute_requests/{document=**} {
      allow read, write: if signedIn();
    }

    /* ==========================
       LECTURE OVERRIDES
       Replacement lecture mapping
    ========================== */
    match /lecture_overrides/{document=**} {
      allow read, write: if signedIn();
    }

    // Default deny for unknown collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
